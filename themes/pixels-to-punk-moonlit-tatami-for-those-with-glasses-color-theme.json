    "gitDecoration.untrackedResourceForeground": "#AEDDB2",
    "gitDecoration.ignoredResourceForeground": "#8B9D94",
    "gitDecoration.conflictingResourceForeground": "#D083AD",
    "gitDecoration.submoduleResourceForeground": "#8BB5DF",
    "gitDecoration.stageModifiedResourceForeground": "#D5BC78",
    "gitDecoration.stageDeletedResourceForeground": "#E87C8A"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9BAEA4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#95CB9A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D5BC78"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D083AD"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#72C9D0"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#E5EEE9"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#CCA47B"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#AAA1D8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#8BB5DF"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#CCD8D2"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#E87C8A"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#E87C8A"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#95CB9A"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D5BC78"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#AAA1D8",
    "enum": "#AAA1D8",
    "function": "#72C9D0",
    "interface": "#AAA1D8",
    "keyword": "#D083AD",
    "method": "#72C9D0",
    "namespace": "#AAA1D8",
    "number": "#D5BC78",
    "parameter": "#CCA47B",
    "property": "#8BB5DF",
    "string": "#95CB9A",
    "type": "#AAA1D8",
    "variable": "#E5EEE9"
  }
}
