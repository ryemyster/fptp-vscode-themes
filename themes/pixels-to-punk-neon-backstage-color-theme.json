    "statusBarItem.activeBackground": "#FF36B7",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#1F1D3B",
    "statusBarItem.remoteBackground": "#5EA8FF",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#FF4C6A",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#FFE05C",
    "statusBarItem.warningForeground": "#101019"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7C83A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FF7A45"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFE05C"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF36B7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#24D9FF"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#EEF3FF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFB15E"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#9C7BFF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#5EA8FF"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#B4B8D6"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#FF4C6A"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF4C6A"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#66F29A"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFE05C"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#9C7BFF",
    "enum": "#9C7BFF",
    "function": "#24D9FF",
    "interface": "#9C7BFF",
    "keyword": "#FF36B7",
    "method": "#24D9FF",
    "namespace": "#9C7BFF",
    "number": "#FFE05C",
    "parameter": "#FFB15E",
    "property": "#5EA8FF",
    "string": "#FF7A45",
    "type": "#9C7BFF",
    "variable": "#EEF3FF"
  }
}
