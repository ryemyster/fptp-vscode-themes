    "terminal.ansiRed": "#FF4C6A",
    "terminal.ansiWhite": "#EEF3FF",
    "terminal.ansiYellow": "#FFE05C",
    "terminal.background": "#0B0B18",
    "terminal.border": "#28264A",
    "terminalCommandDecoration.defaultBackground": "#666B8F",
    "terminalCommandDecoration.errorBackground": "#FF4C6A",
    "terminalCommandDecoration.successBackground": "#66F29A",
