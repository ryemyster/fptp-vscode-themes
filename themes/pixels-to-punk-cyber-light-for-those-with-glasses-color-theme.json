    "gitDecoration.untrackedResourceForeground": "#3B8F5B",
    "gitDecoration.ignoredResourceForeground": "#626B7C",
    "gitDecoration.conflictingResourceForeground": "#9B2E72",
    "gitDecoration.submoduleResourceForeground": "#335F9F",
    "gitDecoration.stageModifiedResourceForeground": "#8B6400",
    "gitDecoration.stageDeletedResourceForeground": "#B7334F"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#626B7C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#287A49"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#8B6400"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9B2E72"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006F7A"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#242A3A"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#965B24"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5F54A8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#335F9F"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#4D5666"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#B7334F"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#B7334F"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#287A49"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#8B6400"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#5F54A8",
    "enum": "#5F54A8",
    "function": "#006F7A",
    "interface": "#5F54A8",
    "keyword": "#9B2E72",
    "method": "#006F7A",
    "namespace": "#5F54A8",
    "number": "#8B6400",
    "parameter": "#965B24",
    "property": "#335F9F",
    "string": "#287A49",
    "type": "#5F54A8",
    "variable": "#242A3A"
  }
}
