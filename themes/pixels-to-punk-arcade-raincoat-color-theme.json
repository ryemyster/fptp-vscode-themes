    "editorWhitespace.foreground": "#3E5B7A",
    "focusBorder": "#3DBBFF",
    "foreground": "#EAF6FF",
    "gitDecoration.addedResourceForeground": "#3DBBFF",
    "gitDecoration.deletedResourceForeground": "#FF5870",
    "gitDecoration.modifiedResourceForeground": "#F8D85A",
    "input.background": "#1A2C43",
    "input.border": "#3E5B7A",
