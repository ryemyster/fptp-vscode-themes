    "terminal.ansiBrightCyan": "#78D8FF",
    "terminal.ansiBrightGreen": "#78D8FF",
    "terminal.ansiBrightMagenta": "#FF7FC8",
    "terminal.ansiBrightRed": "#FF7D8F",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminal.ansiBrightYellow": "#FFE281",
