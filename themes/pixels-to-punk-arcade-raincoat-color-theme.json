    "terminal.ansiGreen": "#3DBBFF",
    "terminal.ansiMagenta": "#FF4FB3",
    "terminal.ansiRed": "#FF5870",
    "terminal.ansiWhite": "#EAF6FF",
    "terminal.ansiYellow": "#F8D85A",
    "terminal.background": "#0B1522",
    "terminal.border": "#293D58",
    "terminalCommandDecoration.defaultBackground": "#71869E",
    "terminalCommandDecoration.errorBackground": "#FF5870",
    "terminalCommandDecoration.successBackground": "#3DBBFF",
