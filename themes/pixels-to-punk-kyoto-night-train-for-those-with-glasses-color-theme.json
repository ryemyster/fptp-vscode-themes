    "gitDecoration.untrackedResourceForeground": "#94DDE7",
    "gitDecoration.ignoredResourceForeground": "#8799AA",
    "gitDecoration.conflictingResourceForeground": "#CF83B6",
    "gitDecoration.submoduleResourceForeground": "#8BB8E5",
    "gitDecoration.stageModifiedResourceForeground": "#D9B679",
    "gitDecoration.stageDeletedResourceForeground": "#E97B8A"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#98A9BA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#D58E8B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D9B679"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#CF83B6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#70CAD6"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#E3EDF5"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#CFA07B"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#A9A4DF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#8BB8E5"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#CAD6E1"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#E97B8A"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#E97B8A"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#70CAD6"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D9B679"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#A9A4DF",
    "enum": "#A9A4DF",
    "function": "#70CAD6",
    "interface": "#A9A4DF",
    "keyword": "#CF83B6",
    "method": "#70CAD6",
    "namespace": "#A9A4DF",
    "number": "#D9B679",
    "parameter": "#CFA07B",
    "property": "#8BB8E5",
    "string": "#D58E8B",
    "type": "#A9A4DF",
    "variable": "#E3EDF5"
  }
}
