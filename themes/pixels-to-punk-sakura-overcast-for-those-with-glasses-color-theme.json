    "gitDecoration.untrackedResourceForeground": "#008A9E",
    "gitDecoration.ignoredResourceForeground": "#736879",
    "gitDecoration.conflictingResourceForeground": "#8F2E68",
    "gitDecoration.submoduleResourceForeground": "#2E5E97",
    "gitDecoration.stageModifiedResourceForeground": "#765A20",
    "gitDecoration.stageDeletedResourceForeground": "#A83451"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6C6171",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#9D3D56"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#765A20"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8F2E68"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006D80"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#2A2430"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#87504B"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#554D9F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#2E5E97"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#564C5A"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#A83451"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#A83451"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#006D80"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#765A20"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#554D9F",
    "enum": "#554D9F",
    "function": "#006D80",
    "interface": "#554D9F",
    "keyword": "#8F2E68",
    "method": "#006D80",
    "namespace": "#554D9F",
    "number": "#765A20",
    "parameter": "#87504B",
    "property": "#2E5E97",
    "string": "#9D3D56",
    "type": "#554D9F",
    "variable": "#2A2430"
  }
}
