    "statusBarItem.remoteBackground": "#8FB5FF",
    "statusBarItem.remoteForeground": "#101019",
    "statusBarItem.errorBackground": "#FF6576",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#FFD06E",
    "statusBarItem.warningForeground": "#101019"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6F9398",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#B7E36F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFD06E"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF7A8A"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#49E0E8"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#DFFBFF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFB184"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8FB5FF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#75D4B8"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#ABD1D6"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#06191D",
        "background": "#FF6576"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF6576"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#B7E36F"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFD06E"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#8FB5FF",
    "enum": "#8FB5FF",
    "function": "#49E0E8",
    "interface": "#8FB5FF",
    "keyword": "#FF7A8A",
    "method": "#49E0E8",
    "namespace": "#8FB5FF",
    "number": "#FFD06E",
    "parameter": "#FFB184",
    "property": "#75D4B8",
    "string": "#B7E36F",
    "type": "#8FB5FF",
    "variable": "#DFFBFF"
  }
}
