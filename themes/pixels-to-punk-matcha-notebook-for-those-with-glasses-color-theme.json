    "statusBar.foreground": "#10181F",
    "statusBar.noFolderBackground": "#E0E8D9",
    "tab.activeBackground": "#F2F5EC",
    "tab.activeBorderTop": "#8E3B68",
    "tab.activeForeground": "#10181F",
