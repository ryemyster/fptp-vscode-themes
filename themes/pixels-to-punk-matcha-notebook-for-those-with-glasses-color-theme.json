    "terminal.ansiCyan": "#006C72",
    "terminal.ansiGreen": "#33704A",
    "terminal.ansiMagenta": "#8E3B68",
    "terminal.ansiRed": "#A83A4C",
    "terminal.ansiWhite": "#202B32",
    "terminal.ansiYellow": "#725F12",
    "terminal.background": "#F2F5EC",
    "terminal.border": "#C3CFB7",
