    "panelInput.border": "#7B8B70",
    "panelTitle.activeBorder": "#8E3B68",
    "panelTitle.activeForeground": "#10181F",
    "panelTitle.inactiveForeground": "#62717B",
    "peekView.border": "#006C72",
    "peekViewEditor.background": "#E8EDE1",
    "peekViewResult.background": "#E0E8D9",
