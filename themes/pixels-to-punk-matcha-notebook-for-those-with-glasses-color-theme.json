    "titleBar.activeBackground": "#E0E8D9",
    "titleBar.activeForeground": "#10181F",
    "titleBar.inactiveBackground": "#F2F5EC",
    "titleBar.inactiveForeground": "#62717B",
    "statusBar.noFolderForeground": "#10181F",
    "statusBarItem.activeBackground": "#8E3B68",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#EBF1E7",
    "statusBarItem.remoteBackground": "#315F8E",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#A83A4C",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#725F12",
    "statusBarItem.warningForeground": "#FFFFFF",
    "gitDecoration.renamedResourceForeground": "#006C72",
    "gitDecoration.untrackedResourceForeground": "#438A5B",
    "gitDecoration.ignoredResourceForeground": "#62717B",
    "gitDecoration.conflictingResourceForeground": "#8E3B68",
    "gitDecoration.submoduleResourceForeground": "#315F8E",
    "gitDecoration.stageModifiedResourceForeground": "#725F12",
    "gitDecoration.stageDeletedResourceForeground": "#A83A4C"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5D6C76",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#33704A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#725F12"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8E3B68"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006C72"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#202B32"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#7B5636"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#595795"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#315F8E"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#48545B"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#A83A4C"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#A83A4C"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#33704A"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#725F12"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#595795",
    "enum": "#595795",
    "function": "#006C72",
    "interface": "#595795",
    "keyword": "#8E3B68",
    "method": "#006C72",
    "namespace": "#595795",
    "number": "#725F12",
    "parameter": "#7B5636",
    "property": "#315F8E",
    "string": "#33704A",
    "type": "#595795",
    "variable": "#202B32"
  }
}
