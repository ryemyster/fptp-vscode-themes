    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#EA7D8E",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#D8BA77",
    "statusBarItem.warningForeground": "#101019",
    "gitDecoration.renamedResourceForeground": "#74C8D5",
    "gitDecoration.untrackedResourceForeground": "#A7DAB2",
    "gitDecoration.ignoredResourceForeground": "#8A94A8",
    "gitDecoration.conflictingResourceForeground": "#CF86B7",
    "gitDecoration.submoduleResourceForeground": "#8DB5E6",
    "gitDecoration.stageModifiedResourceForeground": "#D8BA77",
    "gitDecoration.stageDeletedResourceForeground": "#EA7D8E"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9CA5B8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#8BCB9B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D8BA77"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#CF86B7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#74C8D5"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#E6EAF3"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#D0A17A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#AAA1DF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#8DB5E6"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#CDD3E0"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#EA7D8E"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#EA7D8E"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#8BCB9B"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D8BA77"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#AAA1DF",
    "enum": "#AAA1DF",
    "function": "#74C8D5",
    "interface": "#AAA1DF",
    "keyword": "#CF86B7",
    "method": "#74C8D5",
    "namespace": "#AAA1DF",
    "number": "#D8BA77",
    "parameter": "#D0A17A",
    "property": "#8DB5E6",
    "string": "#8BCB9B",
    "type": "#AAA1DF",
    "variable": "#E6EAF3"
  }
}
