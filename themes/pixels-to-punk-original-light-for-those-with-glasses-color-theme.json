    "terminal.ansiRed": "#B6334D",
    "terminal.ansiWhite": "#23283A",
    "terminal.ansiYellow": "#875A1F",
    "terminal.background": "#F6F2EA",
    "terminal.border": "#C9C0B5",
    "terminalCommandDecoration.defaultBackground": "#626A7C",
    "terminalCommandDecoration.errorBackground": "#B6334D",
    "terminalCommandDecoration.successBackground": "#006D78",
