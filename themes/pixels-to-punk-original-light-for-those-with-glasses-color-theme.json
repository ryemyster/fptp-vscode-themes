    "statusBarItem.activeBackground": "#973060",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#EEECE5",
    "statusBarItem.remoteBackground": "#2F5E97",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#B6334D",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#875A1F",
    "statusBarItem.warningForeground": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#626A7C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#A83F4E"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#875A1F"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#973060"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006D78"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#23283A"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#8D4E35"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5B4F9B"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#2F5E97"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#4C5364"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#B6334D"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#B6334D"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#006D78"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#875A1F"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#5B4F9B",
    "enum": "#5B4F9B",
    "function": "#006D78",
    "interface": "#5B4F9B",
    "keyword": "#973060",
    "method": "#006D78",
    "namespace": "#5B4F9B",
    "number": "#875A1F",
    "parameter": "#8D4E35",
    "property": "#2F5E97",
    "string": "#A83F4E",
    "type": "#5B4F9B",
    "variable": "#23283A"
  }
}
