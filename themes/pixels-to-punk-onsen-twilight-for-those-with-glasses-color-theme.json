    "gitDecoration.untrackedResourceForeground": "#A0DCE4",
    "gitDecoration.ignoredResourceForeground": "#A18B94",
    "gitDecoration.conflictingResourceForeground": "#D58AB7",
    "gitDecoration.submoduleResourceForeground": "#93B1E1",
    "gitDecoration.stageModifiedResourceForeground": "#D8B47A",
    "gitDecoration.stageDeletedResourceForeground": "#EC808D"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B09AA3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#DB9991"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D8B47A"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D58AB7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7FC7D0"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#F0E7EA"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#D1A07D"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B1A0DD"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#93B1E1"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#DED0D5"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#EC808D"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#EC808D"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#7FC7D0"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D8B47A"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#B1A0DD",
    "enum": "#B1A0DD",
    "function": "#7FC7D0",
    "interface": "#B1A0DD",
    "keyword": "#D58AB7",
    "method": "#7FC7D0",
    "namespace": "#B1A0DD",
    "number": "#D8B47A",
    "parameter": "#D1A07D",
    "property": "#93B1E1",
    "string": "#DB9991",
    "type": "#B1A0DD",
    "variable": "#F0E7EA"
  }
}
