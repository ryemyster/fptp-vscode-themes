    "statusBarItem.activeBackground": "#FF73D8",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#2F204B",
    "statusBarItem.remoteBackground": "#78A8FF",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#FF5F7D",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#FFD166",
    "statusBarItem.warningForeground": "#101019"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9A83AD",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FFAA6A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF73D8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#56F0FF"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#F7ECFF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFAA6A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8A5CFF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#78A8FF"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#D8C5E7"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#FF5F7D"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF5F7D"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#56F0FF"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#8A5CFF",
    "enum": "#8A5CFF",
    "function": "#56F0FF",
    "interface": "#8A5CFF",
    "keyword": "#FF73D8",
    "method": "#56F0FF",
    "namespace": "#8A5CFF",
    "number": "#FFD166",
    "parameter": "#FFAA6A",
    "property": "#78A8FF",
    "string": "#FFAA6A",
    "type": "#8A5CFF",
    "variable": "#F7ECFF"
  }
}
