    "statusBarItem.activeBackground": "#8B3C72",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#EAF2F2",
    "statusBarItem.remoteBackground": "#2C6290",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#A63A4C",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#745D18",
    "statusBarItem.warningForeground": "#FFFFFF",
    "gitDecoration.renamedResourceForeground": "#006C80",
    "gitDecoration.untrackedResourceForeground": "#438A61",
    "gitDecoration.ignoredResourceForeground": "#5D6D76",
    "gitDecoration.conflictingResourceForeground": "#8B3C72",
    "gitDecoration.submoduleResourceForeground": "#2C6290",
    "gitDecoration.stageModifiedResourceForeground": "#745D18",
    "gitDecoration.stageDeletedResourceForeground": "#A63A4C"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5C6C75",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#2F704F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#745D18"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8B3C72"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006C80"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#1E2A32"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#765947"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#4F5B9A"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#2C6290"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#46545C"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#A63A4C"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#A63A4C"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#2F704F"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#745D18"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#4F5B9A",
    "enum": "#4F5B9A",
    "function": "#006C80",
    "interface": "#4F5B9A",
    "keyword": "#8B3C72",
    "method": "#006C80",
    "namespace": "#4F5B9A",
    "number": "#745D18",
    "parameter": "#765947",
    "property": "#2C6290",
    "string": "#2F704F",
    "type": "#4F5B9A",
    "variable": "#1E2A32"
  }
}
