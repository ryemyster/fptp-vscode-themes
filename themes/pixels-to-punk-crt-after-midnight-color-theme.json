    "gitDecoration.untrackedResourceForeground": "#A6FFAE",
    "gitDecoration.ignoredResourceForeground": "#577A76",
    "gitDecoration.conflictingResourceForeground": "#F05BC3",
    "gitDecoration.submoduleResourceForeground": "#55A6FF",
    "gitDecoration.stageModifiedResourceForeground": "#FFB84D",
    "gitDecoration.stageDeletedResourceForeground": "#FF5368"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6C918B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#7DFF89"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFB84D"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#F05BC3"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#41E6D1"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#D7FFF4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFCC7A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#55A6FF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#A2F970"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#9DD1C8"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F2FFFB",
        "background": "#FF5368"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF5368"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#7DFF89"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFB84D"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#55A6FF",
    "enum": "#55A6FF",
    "function": "#41E6D1",
    "interface": "#55A6FF",
    "keyword": "#F05BC3",
    "method": "#41E6D1",
    "namespace": "#55A6FF",
    "number": "#FFB84D",
    "parameter": "#FFCC7A",
    "property": "#A2F970",
    "string": "#7DFF89",
    "type": "#55A6FF",
    "variable": "#D7FFF4"
  }
}
