    "titleBar.activeForeground": "#F1EDE2",
    "titleBar.inactiveBackground": "#1B1D20",
    "titleBar.inactiveForeground": "#8F938D"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8C918A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#A9C68F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D5B170"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D79BB1"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#87BFC0"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#DCD8CC"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#C6A27A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B4ABD8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#9EB8D6"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#B6B5AE"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#1B1D20",
        "background": "#E58B96"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#E58B96"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#A9C68F"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D5B170"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#B4ABD8",
    "enum": "#B4ABD8",
    "function": "#87BFC0",
    "interface": "#B4ABD8",
    "keyword": "#D79BB1",
    "method": "#87BFC0",
    "namespace": "#B4ABD8",
    "number": "#D5B170",
    "parameter": "#C6A27A",
    "property": "#9EB8D6",
    "string": "#A9C68F",
    "type": "#B4ABD8",
    "variable": "#DCD8CC"
  }
}
