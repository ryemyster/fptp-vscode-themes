    "terminal.ansiBrightMagenta": "#E8AFC4",
    "terminal.ansiBrightRed": "#F0A0AA",
    "terminal.ansiBrightWhite": "#F1EDE2",
    "terminal.ansiBrightYellow": "#E2C487",
    "terminal.ansiCyan": "#87BFC0",
    "terminal.ansiGreen": "#A9C68F",
    "terminal.ansiMagenta": "#D79BB1",
    "terminal.ansiRed": "#E58B96",
    "terminal.ansiWhite": "#DCD8CC",
    "terminal.ansiYellow": "#D5B170",
    "terminal.background": "#1B1D20",
    "terminal.border": "#343A3F",
    "terminalCommandDecoration.defaultBackground": "#777D7B",
    "terminalCommandDecoration.errorBackground": "#E58B96",
    "terminalCommandDecoration.successBackground": "#A9C68F",
    "terminalCursor.background": "#1B1D20",
    "terminalCursor.foreground": "#CFC5A8",
    "terminal.foreground": "#DCD8CC",
    "terminal.inactiveSelectionBackground": "#39344166",
    "terminal.selectionBackground": "#74657F66",
