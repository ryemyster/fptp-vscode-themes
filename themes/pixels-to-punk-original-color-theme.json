    "terminal.ansiBrightCyan": "#5EEBFF",
    "terminal.ansiBrightGreen": "#2FD7F0",
    "terminal.ansiBrightMagenta": "#F47ABE",
    "terminal.ansiBrightRed": "#F07178",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminal.ansiBrightYellow": "#FF9A78",
    "terminal.ansiCyan": "#2FD7F0",
    "terminal.ansiGreen": "#2FD7F0",
    "terminal.ansiMagenta": "#E051A2",
    "terminal.ansiRed": "#D83668",
    "terminal.ansiWhite": "#F5F5F6",
    "terminal.ansiYellow": "#FF7A5F",
    "terminal.background": "#131B2D",
    "terminal.border": "#343785",
    "terminalCommandDecoration.defaultBackground": "#7A7897",
    "terminalCommandDecoration.errorBackground": "#D83668",
    "terminalCommandDecoration.successBackground": "#2FD7F0",
    "terminalCursor.background": "#131B2D",
    "terminalCursor.foreground": "#2FD7F0",
    "terminal.foreground": "#F5F5F6",
    "terminal.inactiveSelectionBackground": "#2C336766",
    "terminal.selectionBackground": "#54388B66",
