    "editorWarning.foreground": "#FF7A5F",
    "editorWhitespace.foreground": "#54388B",
    "focusBorder": "#2FD7F0",
    "foreground": "#F5F5F6",
    "gitDecoration.addedResourceForeground": "#2FD7F0",
    "gitDecoration.deletedResourceForeground": "#D83668",
    "gitDecoration.modifiedResourceForeground": "#FF7A5F",
    "input.background": "#232858",
    "input.border": "#54388B",
    "input.foreground": "#F5F5F6",
