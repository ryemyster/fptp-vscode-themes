    "statusBar.foreground": "#FFFFFF",
    "statusBar.noFolderBackground": "#10172A",
    "tab.activeBackground": "#131B2D",
    "tab.activeBorderTop": "#E051A2",
    "tab.activeForeground": "#FFFFFF",
    "tab.border": "#343785",
    "tab.inactiveBackground": "#10172A",
    "tab.inactiveForeground": "#8B86A4",
