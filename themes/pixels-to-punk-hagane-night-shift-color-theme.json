    "gitDecoration.untrackedResourceForeground": "#93E3EF",
    "gitDecoration.ignoredResourceForeground": "#8D96AF",
    "gitDecoration.conflictingResourceForeground": "#E477BB",
    "gitDecoration.submoduleResourceForeground": "#91BDF3",
    "gitDecoration.stageModifiedResourceForeground": "#E6B86D",
    "gitDecoration.stageDeletedResourceForeground": "#F2788C"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A0A8C0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#F08A91"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#E6B86D"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E477BB"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6DD2E2"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#EEF1FC"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#DE9F78"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B0A0F0"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#91BDF3"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#D8DDED"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#F2788C"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#F2788C"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#6DD2E2"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#E6B86D"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#B0A0F0",
    "enum": "#B0A0F0",
    "function": "#6DD2E2",
    "interface": "#B0A0F0",
    "keyword": "#E477BB",
    "method": "#6DD2E2",
    "namespace": "#B0A0F0",
    "number": "#E6B86D",
    "parameter": "#DE9F78",
    "property": "#91BDF3",
    "string": "#F08A91",
    "type": "#B0A0F0",
    "variable": "#EEF1FC"
  }
}
