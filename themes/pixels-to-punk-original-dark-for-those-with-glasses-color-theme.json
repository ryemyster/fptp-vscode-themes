    "terminal.ansiBlue": "#8CB9EE",
    "terminal.ansiBrightBlack": "#8B93AA",
    "terminal.ansiBrightBlue": "#A8CCF6",
    "terminal.ansiBrightCyan": "#91E1EA",
    "terminal.ansiBrightGreen": "#91E1EA",
    "terminal.ansiBrightMagenta": "#E79BC9",
    "terminal.ansiBrightRed": "#F292A1",
    "terminal.ansiBrightWhite": "#FAFBFF",
    "terminal.ansiBrightYellow": "#EDB58D",
    "terminal.ansiCyan": "#6ED0DD",
    "terminal.ansiGreen": "#6ED0DD",
    "terminal.ansiMagenta": "#D970B1",
    "terminal.ansiRed": "#F06F85",
    "terminal.ansiWhite": "#E8ECF4",
    "terminal.ansiYellow": "#E6A074",
    "terminal.background": "#101827",
    "terminal.border": "#354266",
    "terminalCommandDecoration.defaultBackground": "#8B93AA",
    "terminalCommandDecoration.errorBackground": "#F06F85",
    "terminalCommandDecoration.successBackground": "#6ED0DD",
    "terminalCursor.background": "#101827",
    "terminalCursor.foreground": "#7BD8E4",
