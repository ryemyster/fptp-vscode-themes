    "titleBar.activeBackground": "#172033",
    "titleBar.activeForeground": "#FAFBFF",
    "titleBar.inactiveBackground": "#101827",
    "titleBar.inactiveForeground": "#969CB0",
    "statusBar.noFolderForeground": "#FAFBFF",
    "statusBarItem.activeBackground": "#D970B1",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#242F4C",
    "statusBarItem.remoteBackground": "#8CB9EE",
    "statusBarItem.remoteForeground": "#101019",
    "statusBarItem.errorBackground": "#F06F85",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#E6A074",
    "statusBarItem.warningForeground": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A0A7B8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E4868C"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#E6A074"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D970B1"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6ED0DD"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#E8ECF4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#D997A1"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#A99BE7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#8CB9EE"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#D2D6E0"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#F06F85"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#F06F85"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#6ED0DD"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#E6A074"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#A99BE7",
    "enum": "#A99BE7",
    "function": "#6ED0DD",
    "interface": "#A99BE7",
    "keyword": "#D970B1",
    "method": "#6ED0DD",
    "namespace": "#A99BE7",
    "number": "#E6A074",
    "parameter": "#D997A1",
    "property": "#8CB9EE",
    "string": "#E4868C",
    "type": "#A99BE7",
    "variable": "#E8ECF4"
  }
}
