    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#1F272F",
    "statusBarItem.remoteBackground": "#79B7D6",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#E15E6E",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#E0AF57",
    "statusBarItem.warningForeground": "#101019"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#778281",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E0AF57"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#CFA05D"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D36F86"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#79B7D6"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#E7ECEB"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#D59A72"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#A696D8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#8CB8BE"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#B1B9B8"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#E15E6E"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#E15E6E"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#80C083"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#E0AF57"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#A696D8",
    "enum": "#A696D8",
    "function": "#79B7D6",
    "interface": "#A696D8",
    "keyword": "#D36F86",
    "method": "#79B7D6",
    "namespace": "#A696D8",
    "number": "#CFA05D",
    "parameter": "#D59A72",
    "property": "#8CB8BE",
    "string": "#E0AF57",
    "type": "#A696D8",
    "variable": "#E7ECEB"
  }
}
