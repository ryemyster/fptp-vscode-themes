    "editorSuggestWidget.selectedBackground": "#2C356A",
    "editorWarning.foreground": "#FFE45C",
    "editorWhitespace.foreground": "#48518A",
    "focusBorder": "#00F0FF",
    "foreground": "#F2F5FF",
    "gitDecoration.addedResourceForeground": "#00F0FF",
    "gitDecoration.deletedResourceForeground": "#FF5C7A",
    "gitDecoration.modifiedResourceForeground": "#FFE45C",
    "input.background": "#1D244B",
    "input.border": "#48518A",
    "input.foreground": "#F2F5FF",
    "input.placeholderForeground": "#8994C0",
    "list.activeSelectionBackground": "#2C356A",
