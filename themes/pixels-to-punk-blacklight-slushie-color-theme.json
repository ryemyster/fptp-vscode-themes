    "terminal.ansiBrightCyan": "#70F7FF",
    "terminal.ansiBrightGreen": "#70F7FF",
    "terminal.ansiBrightMagenta": "#FF7CE5",
    "terminal.ansiBrightRed": "#FF7B91",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminal.ansiBrightYellow": "#FFEF8A",
    "terminal.ansiCyan": "#00F0FF",
    "terminal.ansiGreen": "#00F0FF",
    "terminal.ansiMagenta": "#FF4FD8",
    "terminal.ansiRed": "#FF5C7A",
    "terminal.ansiWhite": "#F2F5FF",
    "terminal.ansiYellow": "#FFE45C",
    "terminal.background": "#0D1026",
    "terminal.border": "#2E3766",
    "terminalCommandDecoration.defaultBackground": "#7A86B3",
    "terminalCommandDecoration.errorBackground": "#FF5C7A",
    "terminalCommandDecoration.successBackground": "#00F0FF",
    "terminalCursor.background": "#0D1026",
    "terminalCursor.foreground": "#00F0FF",
    "terminal.foreground": "#F2F5FF",
    "terminal.inactiveSelectionBackground": "#2C356A66",
    "terminal.selectionBackground": "#8B5CFF55",
