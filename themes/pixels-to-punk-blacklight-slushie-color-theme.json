    "panelTitle.activeBorder": "#FF4FD8",
    "panelTitle.activeForeground": "#FFFFFF",
    "panelTitle.inactiveForeground": "#8994C0",
    "peekView.border": "#00F0FF",
    "peekViewEditor.background": "#121735",
    "peekViewResult.background": "#151A3A",
