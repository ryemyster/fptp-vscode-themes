    "statusBar.debuggingForeground": "#FFFFFF",
    "statusBar.foreground": "#000000",
    "statusBar.noFolderBackground": "#E7D8FF",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeBorderTop": "#B800E6",
    "tab.activeForeground": "#000000",
    "tab.border": "#C1A3F0",
    "tab.inactiveBackground": "#E7D8FF",
    "tab.inactiveForeground": "#5B4B68",
    "terminal.ansiBlack": "#13091C",
    "terminal.ansiBlue": "#004FB8",
    "terminal.ansiBrightBlack": "#5B4B68",
    "terminal.ansiBrightBlue": "#006DDF",
    "terminal.ansiBrightCyan": "#0088C7",
    "terminal.ansiBrightGreen": "#006B99",
    "terminal.ansiBrightMagenta": "#D12BFF",
    "terminal.ansiBrightRed": "#E02F5A",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminal.ansiBrightYellow": "#A66D00",
    "terminal.ansiCyan": "#006B99",
    "terminal.ansiGreen": "#006B99",
    "terminal.ansiMagenta": "#B800E6",
    "terminal.ansiRed": "#C9003A",
    "terminal.ansiWhite": "#13091C",
    "terminal.ansiYellow": "#8A5700",
    "terminal.background": "#FFFFFF",
    "terminal.border": "#C1A3F0",
    "terminalCommandDecoration.defaultBackground": "#665A72",
    "terminalCommandDecoration.errorBackground": "#C9003A",
    "terminalCommandDecoration.successBackground": "#006B99",
    "terminalCursor.background": "#FFFFFF",
    "terminalCursor.foreground": "#B800E6",
    "terminal.foreground": "#13091C",
    "terminal.inactiveSelectionBackground": "#DCCCFF66",
    "terminal.selectionBackground": "#006B9938",
    "terminal.selectionForeground": "#000000",
    "titleBar.activeBackground": "#E7D8FF",
    "titleBar.activeForeground": "#000000",
    "titleBar.inactiveBackground": "#FFFFFF",
    "titleBar.inactiveForeground": "#5B4B68",
    "statusBar.noFolderForeground": "#000000",
    "statusBarItem.activeBackground": "#B800E6",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#F0E7FF",
    "statusBarItem.remoteBackground": "#004FB8",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#C9003A",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#8A5700",
    "statusBarItem.warningForeground": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5A4A66",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#C43D00"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#8A5700"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B800E6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006B99"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#13091C"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#B53600"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#4D25B8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#004FB8"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#33283D"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#C9003A"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#C9003A"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#006B99"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#8A5700"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#4D25B8",
    "enum": "#4D25B8",
    "function": "#006B99",
    "interface": "#4D25B8",
    "keyword": "#B800E6",
    "method": "#006B99",
    "namespace": "#4D25B8",
    "number": "#8A5700",
    "parameter": "#B53600",
    "property": "#004FB8",
    "string": "#C43D00",
    "type": "#4D25B8",
    "variable": "#13091C"
  }
}
