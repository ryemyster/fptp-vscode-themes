    "editorBracketHighlight.foreground2": "#B800E6",
    "editorBracketHighlight.foreground3": "#8A5700",
    "editorCursor.foreground": "#B800E6",
    "editorError.foreground": "#C9003A",
    "editorGroup.border": "#C1A3F0",
