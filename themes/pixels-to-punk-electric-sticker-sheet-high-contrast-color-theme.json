    "focusBorder": "#006B99",
    "foreground": "#13091C",
    "gitDecoration.addedResourceForeground": "#006B99",
    "gitDecoration.deletedResourceForeground": "#C9003A",
    "gitDecoration.modifiedResourceForeground": "#8A5700",
    "input.background": "#FFFFFF",
    "input.border": "#8C63CF",
    "input.foreground": "#13091C",
    "input.placeholderForeground": "#5B4B68",
    "list.activeSelectionBackground": "#DCCCFF",
    "list.activeSelectionForeground": "#000000",
    "list.focusBackground": "#E8DAFF",
    "list.highlightForeground": "#006B99",
    "list.hoverBackground": "#F0E7FF",
    "list.inactiveSelectionBackground": "#E9DEFA",
    "list.errorForeground": "#C9003A",
    "list.warningForeground": "#8A5700",
    "menu.background": "#FFFFFF",
    "menu.foreground": "#13091C",
    "menu.selectionBackground": "#DCCCFF",
    "panel.background": "#E7D8FF",
    "panel.border": "#C1A3F0",
    "panelInput.border": "#8C63CF",
    "panelTitle.activeBorder": "#B800E6",
    "panelTitle.activeForeground": "#000000",
    "panelTitle.inactiveForeground": "#5B4B68",
    "peekView.border": "#006B99",
    "peekViewEditor.background": "#F4EEFF",
    "peekViewResult.background": "#E7D8FF",
