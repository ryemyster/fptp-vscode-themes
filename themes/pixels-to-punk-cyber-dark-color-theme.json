    "terminal.selectionForeground": "#FFFFFF",
    "titleBar.activeBackground": "#151421",
    "titleBar.activeForeground": "#EAF0FF",
    "titleBar.inactiveBackground": "#101019",
    "titleBar.inactiveForeground": "#8587A6",
    "statusBar.noFolderForeground": "#EAF0FF",
    "statusBarItem.activeBackground": "#FF4FD8",
    "statusBarItem.activeForeground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#1F1E35",
    "statusBarItem.remoteBackground": "#6EA8FF",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#FF5C7A",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#FFD166",
    "statusBarItem.warningForeground": "#101019"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8587A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#7EF29D"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF4FD8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2DE2E6"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#E8EDF7"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFB86C"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B893FF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#6EA8FF"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#A5A8C4"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#D7265F"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF5C7A"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#7EF29D"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#B893FF",
    "enum": "#B893FF",
    "function": "#2DE2E6",
    "interface": "#B893FF",
    "keyword": "#FF4FD8",
    "method": "#2DE2E6",
    "namespace": "#B893FF",
    "number": "#FFD166",
    "parameter": "#FFB86C",
    "property": "#6EA8FF",
    "string": "#7EF29D",
    "type": "#B893FF",
    "variable": "#E8EDF7"
  }
}
