    "tab.border": "#24233A",
    "tab.inactiveBackground": "#151421",
    "tab.inactiveForeground": "#8F91AF",
    "terminal.ansiBlack": "#101019",
    "terminal.ansiBlue": "#6EA8FF",
    "terminal.ansiBrightBlack": "#5E607F",
