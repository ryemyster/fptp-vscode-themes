    "terminal.ansiBrightCyan": "#7AF7FF",
    "terminal.ansiBrightGreen": "#A6F7BC",
    "terminal.ansiBrightMagenta": "#FF7CE5",
    "terminal.ansiBrightRed": "#FF7B91",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminal.ansiBrightYellow": "#FFE08A",
    "terminal.ansiCyan": "#2DE2E6",
    "terminal.ansiGreen": "#7EF29D",
    "terminal.ansiMagenta": "#FF4FD8",
    "terminal.ansiRed": "#FF5C7A",
    "terminal.ansiWhite": "#E8EDF7",
    "terminal.ansiYellow": "#FFD166",
    "terminal.background": "#101019",
    "terminal.border": "#2A2940",
    "terminalCommandDecoration.defaultBackground": "#5E607F",
    "terminalCommandDecoration.errorBackground": "#FF5C7A",
    "terminalCommandDecoration.successBackground": "#7EF29D",
    "terminalCursor.background": "#101019",
    "terminalCursor.foreground": "#2DE2E6",
    "terminal.foreground": "#E8EDF7",
    "terminal.inactiveSelectionBackground": "#2B2A4255",
