    "gitDecoration.untrackedResourceForeground": "#0088A5",
    "gitDecoration.ignoredResourceForeground": "#667286",
    "gitDecoration.conflictingResourceForeground": "#A1267B",
    "gitDecoration.submoduleResourceForeground": "#2D609E",
    "gitDecoration.stageModifiedResourceForeground": "#785D00",
    "gitDecoration.stageDeletedResourceForeground": "#B2304D"
