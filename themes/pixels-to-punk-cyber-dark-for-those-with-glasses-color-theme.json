    "terminal.ansiCyan": "#68C6D0",
    "terminal.ansiGreen": "#82C995",
    "terminal.ansiMagenta": "#D879B8",
    "terminal.ansiRed": "#F07A8D",
    "terminal.ansiWhite": "#E3E8F2",
    "terminal.ansiYellow": "#D7B86B",
    "terminal.background": "#161823",
    "terminal.border": "#31354A",
    "terminalCommandDecoration.defaultBackground": "#838BA0",
    "terminalCommandDecoration.errorBackground": "#F07A8D",
    "terminalCommandDecoration.successBackground": "#82C995",
