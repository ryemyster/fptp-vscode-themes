    "statusBarItem.remoteForeground": "#FFFFFF",
    "statusBarItem.errorBackground": "#FF4E5F",
    "statusBarItem.errorForeground": "#FFFFFF",
    "statusBarItem.warningBackground": "#FFE14D",
    "statusBarItem.warningForeground": "#101019"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A089C4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#B6FF3D"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFE14D"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF35B8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00E7FF"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#F8F2FF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FF944D"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B58AFF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#66A8FF"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#D8C9F4"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#FF4E5F"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF4E5F"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#B6FF3D"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFE14D"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#B58AFF",
    "enum": "#B58AFF",
    "function": "#00E7FF",
    "interface": "#B58AFF",
    "keyword": "#FF35B8",
    "method": "#00E7FF",
    "namespace": "#B58AFF",
    "number": "#FFE14D",
    "parameter": "#FF944D",
    "property": "#66A8FF",
    "string": "#B6FF3D",
    "type": "#B58AFF",
    "variable": "#F8F2FF"
  }
}
