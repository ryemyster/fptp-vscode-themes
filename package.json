{
  "name": "pixels-to-punk-cyber",
  "displayName": "Pixels to Punk Cyber",
  "description": "Cyberpunk VS Code themes inspired by loud product energy, pop punk color, and anime glow.",
  "version": "1.0.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ryemyster/fptp-vscode-themes.git"
  },
  "bugs": {
    "url": "https://github.com/ryemyster/fptp-vscode-themes/issues"
  },
  "homepage": "https://github.com/ryemyster/fptp-vscode-themes#readme",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "contributes": {
    "iconThemes": [
      {
        "id": "pixels-to-punk-cyber-icons",
        "label": "Pixels to Punk Cyber Icons",
        "path": "./icons/pixels-to-punk-cyber-icon-theme.json"
      },
      {
        "id": "pixels-to-punk-cyber-icons-light",
        "label": "Pixels to Punk Cyber Icons Light",
        "path": "./icons/pixels-to-punk-cyber-light-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "workbench.iconTheme": "pixels-to-punk-cyber-icons"
    },
    "themes": [
      {
        "label": "Pixels to Punk Cyber Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/pixels-to-punk-cyber-dark-color-theme.json"
      },
      {
        "label": "Pixels to Punk Cyber Light",
        "uiTheme": "vs",
        "path": "./themes/pixels-to-punk-cyber-light-color-theme.json"
      },
      {
        "label": "Pixels to Punk Neon Backstage",
        "uiTheme": "vs-dark",
        "path": "./themes/pixels-to-punk-neon-backstage-color-theme.json"
      },
      {
        "label": "Pixels to Punk Basement Flyer",
        "uiTheme": "vs-dark",
        "path": "./themes/pixels-to-punk-basement-flyer-color-theme.json"
      },
      {
        "label": "Pixels to Punk CRT After Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/pixels-to-punk-crt-after-midnight-color-theme.json"
      },
      {
        "label": "Pixels to Punk Candy Static",
        "uiTheme": "vs",
        "path": "./themes/pixels-to-punk-candy-static-color-theme.json"
      },
      {
        "label": "Pixels to Punk Streetlight Noir",
        "uiTheme": "vs-dark",
        "path": "./themes/pixels-to-punk-streetlight-noir-color-theme.json"
      },
      {
        "label": "Pixels to Punk Soft Focus Day",
        "uiTheme": "vs",
        "path": "./themes/pixels-to-punk-soft-focus-day-color-theme.json"
      },
      {
        "label": "Pixels to Punk Soft Focus Night",
        "uiTheme": "vs-dark",
        "path": "./themes/pixels-to-punk-soft-focus-night-color-theme.json"
      }
    ]
  },
  "scripts": {
    "clean": "rm -rf node_modules pixels-to-punk-cyber-*.vsix",
    "demo:terminal-colors": "node scripts/terminal-colors.js",
    "package": "npx --no-install vsce package --allow-missing-repository",
    "install:vsix": "code --install-extension pixels-to-punk-cyber-1.0.0.vsix --force"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  }
}
