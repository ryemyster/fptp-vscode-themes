        "uiTheme": "vs",
        "path": "./themes/pixels-to-punk-soft-focus-day-color-theme.json"
      },
      {
        "label": "Pixels to Punk Soft Focus Night",
        "uiTheme": "vs-dark",
        "path": "./themes/pixels-to-punk-soft-focus-night-color-theme.json"
      },
      {
        "label": "Pixels to Punk Rainy Arcade",
